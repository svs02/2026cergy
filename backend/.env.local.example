# 서버
PORT=4000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cergy2026

# 세션
SESSION_SECRET=your-session-secret-here

# 관리자 비밀번호 (bcrypt 해시값)
# 해시 생성: node -e "require('bcryptjs').hash('비밀번호', 10).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=$2b$10$your-bcrypt-hash-here

# Resend (선택). 비워두면 로그인 알림 이메일 발송 skip
RESEND_API_KEY=
ADMIN_EMAIL=
ADMIN_NOTIFICATION_FROM=onboarding@resend.dev

# Storage (Vercel Blob 또는 AWS S3 중 택일)
# Vercel Blob
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# AWS S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-2
# AWS_S3_BUCKET=
